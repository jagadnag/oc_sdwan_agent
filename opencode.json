{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "agent": {
    "sdwan-architect": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./.opencode/agents/sdwan-architect.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "deny"
      }
    },
    "sdwan-troubleshooter": {
      "mode": "all",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./.opencode/agents/sdwan-troubleshooter.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "deny"
      }
    },
    "sdwan-operator": {
      "mode": "all",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./.opencode/agents/sdwan-operator.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "deny"
      }
    }
  },
  "mcp": {
    "sdwan-tools": {
      "type": "local",
      "command": ["python", "src/mcp_server.py"],
      "environment": {
        "PYTHONPATH": "src",
        "LOG_LEVEL": "INFO"
      },
      "enabled": true
    }
  },
  "instructions": ["AGENTS.md"],
  "default_agent": "sdwan-architect"
}

